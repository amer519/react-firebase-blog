rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Admin-only write for blog images
    match /blog_images/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == 'vqwpiGlbosQWkuSkfI5aFXdaAiZ2';
    }

    // Admin-only write for drop images
    match /drop_images/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == 'vqwpiGlbosQWkuSkfI5aFXdaAiZ2';
    }
  }
}
